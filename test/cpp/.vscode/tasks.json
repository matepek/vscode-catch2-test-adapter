{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "echo",
            "type": "shell",
            "command": "echo Hello ${command:cmake.buildDirectory}",
            "problemMatcher": []
        },
        {
            "label": "make build-tests",
            "type": "shell",
            "command": "echo",
            "args": [
                "Paths:", "${absPathConcatWithSpace}", "${absPathArrayFlat}", "..."
            ],
        },
        {
            "label": "echo-testmate2",
            "type": "shell",
            "command": "echo",
            "args": [
                "x2", "${command:testMate.cmd.get-debug-exec}", "${workspaceDirectory}"
            ],
        },
        {
            "label": "echo-testmate",
            "type": "shell",
            "command": "echo",
            "args": [
                "x", "${command:testMate.cmd.get-debug-exec}", "${workspaceDirectory}"
            ],
            "dependsOn": ["echo-testmate2"]
        },
        {
            "label": "exit-1",
            "type": "shell",
            "command": "exit",
            "args": [
                "1"
            ],
        }
    ]
}